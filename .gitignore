Backend/selftest_planner.py
Backend/app/Detectortesting.py
Backend/minor_tests/
frontend/src/App.test.js
frontend/src/setupTests.js

# ===== Build-only data inputs/outputs (runtime uses the parquet index) =====
Backend/data/build/
Backend/data/chatbot_data.csv
Backend/data/merged_final_df.csv

