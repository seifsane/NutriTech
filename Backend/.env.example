# Copy this file to `.env` (same folder) and fill in your own values.
# The real .env is gitignored so secrets never get committed.

GEMINI_API_KEY=
JWT_SECRET_KEY=

# Optional: backup Gemini keys for automatic rotation when one hits its quota.
# Comma-separated; tried in order after GEMINI_API_KEY.
GEMINI_API_KEYS=

# Optional: USDA FoodData Central key for food search (falls back to DEMO_KEY).
USDA_API_KEY=
